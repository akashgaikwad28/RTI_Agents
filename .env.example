# ── App ───────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=                        # Optional fallback

# ── LLM Models ────────────────────────────────────────────────────
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-pro
GEMINI_EMBEDDING_MODEL=models/embedding-001
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3
CIRCUIT_BREAKER_THRESHOLD=5

# ── MongoDB ───────────────────────────────────────────────────────
# Local MongoDB: mongodb://localhost:27017/
# Cloud MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rti_db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=rti_db

# ── Redis (Semantic Cache & Rate Limits) ──────────────────────────
# Local Redis: redis://localhost:6379/0
# Serverless Upstash Redis: rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_SEMANTIC_CACHE_TTL=3600
REDIS_SESSION_TTL=1800

# ── Checkpointer Configuration ────────────────────────────────────
# sqlite: Saves graph thread state locally (SQLite db)
# postgres: Saves graph thread state to Neon Serverless Postgres (highly available/multi-instance)
CHECKPOINTER_TYPE=sqlite              # sqlite | postgres
POSTGRES_CHECKPOINTER_URL=            # Required if CHECKPOINTER_TYPE=postgres (e.g. postgresql://<user>:<password>@<neon-host>/neondb?sslmode=require)

# ── RAG ───────────────────────────────────────────────────────────
VECTORSTORE_TYPE=faiss                # faiss (local file-based) | mongodb (cloud serverless MongoDB Atlas)
FAISS_INDEX_PATH=data/vector_store
FAISS_TOP_K=5
FAISS_ALLOW_DANGEROUS_DESERIALIZATION=false
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
CHUNK_SIZE=512
CHUNK_OVERLAP=80
SCRAPE_INTERVAL_HOURS=24
MAX_SCRAPE_DEPTH=1
EMBEDDING_BATCH_SIZE=32
RAG_CACHE_TTL=3600
MAX_PDF_SIZE_MB=25

# ── LangGraph ─────────────────────────────────────────────────────
CHECKPOINTER_DB=data/checkpoints/rti_checkpoints.db
MAX_REFLECTION_RETRIES=2
HUMAN_APPROVAL_REQUIRED=true
APPROVAL_TIMEOUT_HOURS=24

# ── Security ──────────────────────────────────────────────────────
RTI_API_KEY=change-me-before-production
MAX_QUERY_LENGTH=2000
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_IP=20

# ── Email ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
ADMIN_EMAIL=admin@rti-system.com

# ── LangSmith (Optional) ──────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=rti-agent-prod

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Deployment ────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
WORKERS=1
